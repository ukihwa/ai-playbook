#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SOURCE_PATH}" ]]; do
	SOURCE_DIR="$(cd -P "$(dirname "${SOURCE_PATH}")" && pwd)"
	SOURCE_PATH="$(readlink "${SOURCE_PATH}")"
	[[ "${SOURCE_PATH}" != /* ]] && SOURCE_PATH="${SOURCE_DIR}/${SOURCE_PATH}"
done
ROOT_DIR="$(cd -P "$(dirname "${SOURCE_PATH}")/.." && pwd)"
TMUX_DIR="${ROOT_DIR}/scripts/tmux"
CONFIG_DIR="${ROOT_DIR}/config"

usage() {
	cat <<'EOF'
Usage: workspace <command> <project> [args]
       ws <command> <project> [args]

Commands:
  init-project <project>          Create project config, docs, and triage commands
  up <project>                    Create the base tmux session
  up-bootstrap <project>          Create the base session and bootstrap default Claude panes
  dev <project>                   Create the base session and start FE/BE runtimes
  all <project>                   Create the base session, bootstrap defaults, and start FE/BE runtimes
  run <project> <fe|be|app>       Start a configured runtime window
  stop-run <project> <fe|be|app>  Stop a configured runtime window
  status <project>                Show tmux and worktree status
  intake-history <project>        Show recent intake classification decisions
  intake-report <project>         Summarize intake classification decisions
  intake-tune <project>           Highlight likely intake false positives/negatives
  queue <project>                 Show dispatch ticket queue
  history <project>               Show recent done/blocked/canceled tickets
  report <project>                Summarize dispatch ticket state
  daily-report <project>          Draft one-line daily report items from tickets
  finish-task <project> <id>      Mark, archive, and clean up a completed task
  approve-review <project> <id>   Approve a done-awaiting-review ticket and finish it
  repair-tasks <project>          Find shell-only stuck task windows and repair them
  apply-ticket <project> <id>     Execute a proposed dispatch ticket
  approve-ticket <project> <id>   Approve a needs-triage ticket and execute it
  reject-ticket <project> <id>    Reject a needs-triage ticket
  request-triage <project> <id>   Mark a ticket as needs-triage
  mark-ticket <project> <id>      Update a dispatch ticket status
  dispatch-watch <project>        Watch a dispatch inbox directory and enqueue requests
  enqueue-dispatch <project>      Create a dispatch inbox request file from text or markdown
  intake <project>                Classify a natural-language request and process actionable ones once
  watch <project>                 Start a tmux dispatch watcher window
  stop-watch <project>            Stop the tmux dispatch watcher window
  archive-ticket <project> <id>   Move a ticket to the archive directory
  archive-completed <project>     Archive completed or terminal-status tickets
  task <project> <target> <slug>  Create a worker window and worktree
  start-task <project> ...        Create a worker, generate handoff, and send it
  task-from-spec <project> ...    Start a task from a spec or issue markdown file
  dispatch <project> ...          Propose or apply a task plan from natural language or markdown
  review <project> ...            Create a review window
  start-review <project> ...      Create a review window, generate artifact, and send it
  handoff <project> ...           Send an existing handoff file into a pane
  cleanup <project> ...           Remove task/review windows and optionally the worktree
  projects                        List available project configs
  help                            Show this help
EOF
}

need_script() {
	local path="$1"
	[[ -x "${path}" ]] || {
		echo "error: missing executable: ${path}" >&2
		exit 1
	}
}

resolve_config() {
	local project="$1"
	local path="${CONFIG_DIR}/${project}.env"
	[[ -f "${path}" ]] || {
		echo "error: project config not found: ${path}" >&2
		exit 1
	}
	printf '%s' "${path}"
}

list_projects() {
	find "${CONFIG_DIR}" -maxdepth 1 -type f -name '*.env' -print \
		| sed -E 's#.*/([^/]+)\.env$#\1#' \
		| sort
}

runtime_configured() {
	local config_file="$1"
	local runtime_name="$2"
	local key
	key="$(printf '%s' "${runtime_name}" | tr '[:lower:]-' '[:upper:]_')"
	local value
	value="$(grep -E "^RUN_${key}_CMD=" "${config_file}" | tail -n 1 | cut -d'=' -f2- || true)"
	[[ -n "${value}" ]]
}

for script in \
	"${TMUX_DIR}/init-product.sh" \
	"${TMUX_DIR}/start-runtime.sh" \
	"${TMUX_DIR}/stop-runtime.sh" \
	"${TMUX_DIR}/status.sh" \
	"${TMUX_DIR}/intake-history.sh" \
	"${TMUX_DIR}/intake-report.sh" \
	"${TMUX_DIR}/intake-tune.sh" \
	"${TMUX_DIR}/queue.sh" \
	"${TMUX_DIR}/history.sh" \
	"${TMUX_DIR}/report.sh" \
	"${TMUX_DIR}/daily-report.sh" \
	"${TMUX_DIR}/finish-task.sh" \
	"${TMUX_DIR}/repair-tasks.sh" \
	"${TMUX_DIR}/apply-ticket.sh" \
	"${TMUX_DIR}/approve-ticket.sh" \
	"${TMUX_DIR}/reject-ticket.sh" \
	"${TMUX_DIR}/request-triage.sh" \
	"${TMUX_DIR}/mark-ticket.sh" \
	"${TMUX_DIR}/dispatch-watch.sh" \
	"${TMUX_DIR}/intake.sh" \
	"${TMUX_DIR}/start-watch.sh" \
	"${TMUX_DIR}/stop-watch.sh" \
	"${TMUX_DIR}/triage-bridge.sh" \
	"${TMUX_DIR}/archive-ticket.sh" \
	"${TMUX_DIR}/archive-completed.sh" \
	"${ROOT_DIR}/scripts/setup/init-project.sh" \
	"${ROOT_DIR}/scripts/helpers/create-dispatch-request.sh" \
	"${TMUX_DIR}/new-task.sh" \
	"${TMUX_DIR}/start-task.sh" \
	"${TMUX_DIR}/start-task-from-spec.sh" \
	"${TMUX_DIR}/dispatch.sh" \
	"${TMUX_DIR}/review-task.sh" \
	"${TMUX_DIR}/start-review.sh" \
	"${TMUX_DIR}/handoff.sh" \
	"${TMUX_DIR}/cleanup-task.sh"
do
	need_script "${script}"
done

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
	shift
fi

case "${COMMAND}" in
	help|-h|--help)
		usage
		exit 0
		;;
	projects)
		list_projects
		exit 0
		;;
	init-project)
		PROJECT="${1:-}"
		[[ -n "${PROJECT}" ]] || {
			echo "error: missing project name" >&2
			echo >&2
			usage >&2
			exit 1
		}
		shift
		exec "${ROOT_DIR}/scripts/setup/init-project.sh" "${PROJECT}" "$@"
		;;
esac

PROJECT="${1:-}"
[[ -n "${PROJECT}" ]] || {
	echo "error: missing project name" >&2
	echo >&2
	usage >&2
	exit 1
}
shift

CONFIG_FILE="$(resolve_config "${PROJECT}")"

case "${COMMAND}" in
	up)
		exec "${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" "$@"
		;;
	up-bootstrap)
		exec "${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" --bootstrap-defaults "$@"
		;;
	dev)
		"${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" "$@"
		if runtime_configured "${CONFIG_FILE}" be; then
			"${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait be
		fi
		if runtime_configured "${CONFIG_FILE}" fe; then
			exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait fe
		fi
		exit 0
		;;
	all)
		"${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" --bootstrap-defaults "$@"
		if runtime_configured "${CONFIG_FILE}" be; then
			"${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait be
		fi
		if runtime_configured "${CONFIG_FILE}" fe; then
			exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait fe
		fi
		exit 0
		;;
	run)
		exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" "$@"
		;;
	stop-run)
		exec "${TMUX_DIR}/stop-runtime.sh" --config "${CONFIG_FILE}" "$@"
		;;
	status)
		exec "${TMUX_DIR}/status.sh" --config "${CONFIG_FILE}" "$@"
		;;
	intake-history)
		exec "${TMUX_DIR}/intake-history.sh" --config "${CONFIG_FILE}" "$@"
		;;
	intake-report)
		exec "${TMUX_DIR}/intake-report.sh" --config "${CONFIG_FILE}" "$@"
		;;
	intake-tune)
		exec "${TMUX_DIR}/intake-tune.sh" --config "${CONFIG_FILE}" "$@"
		;;
	queue)
		exec "${TMUX_DIR}/queue.sh" --config "${CONFIG_FILE}" "$@"
		;;
	history)
		exec "${TMUX_DIR}/history.sh" --config "${CONFIG_FILE}" "$@"
		;;
	report)
		exec "${TMUX_DIR}/report.sh" --config "${CONFIG_FILE}" "$@"
		;;
	daily-report)
		exec "${TMUX_DIR}/daily-report.sh" --config "${CONFIG_FILE}" "$@"
		;;
	finish-task)
		exec "${TMUX_DIR}/finish-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	approve-review)
		exec "${TMUX_DIR}/finish-task.sh" --config "${CONFIG_FILE}" --status done "$@"
		;;
	repair-tasks)
		exec "${TMUX_DIR}/repair-tasks.sh" --config "${CONFIG_FILE}" "$@"
		;;
	apply-ticket)
		exec "${TMUX_DIR}/apply-ticket.sh" --config "${CONFIG_FILE}" "$@"
		;;
	approve-ticket)
		exec "${TMUX_DIR}/approve-ticket.sh" --config "${CONFIG_FILE}" "$@"
		;;
	reject-ticket)
		exec "${TMUX_DIR}/reject-ticket.sh" --config "${CONFIG_FILE}" "$@"
		;;
	request-triage)
		exec "${TMUX_DIR}/request-triage.sh" --config "${CONFIG_FILE}" "$@"
		;;
	mark-ticket)
		exec "${TMUX_DIR}/mark-ticket.sh" --config "${CONFIG_FILE}" "$@"
		;;
	dispatch-watch)
		exec "${TMUX_DIR}/dispatch-watch.sh" --config "${CONFIG_FILE}" "$@"
		;;
	enqueue-dispatch)
		exec "${ROOT_DIR}/scripts/helpers/create-dispatch-request.sh" --config "${CONFIG_FILE}" "$@"
		;;
	intake)
		exec "${TMUX_DIR}/intake.sh" --config "${CONFIG_FILE}" "$@"
		;;
	watch)
		exec "${TMUX_DIR}/start-watch.sh" --config "${CONFIG_FILE}" "$@"
		;;
	stop-watch)
		exec "${TMUX_DIR}/stop-watch.sh" --config "${CONFIG_FILE}" "$@"
		;;
	archive-ticket)
		exec "${TMUX_DIR}/archive-ticket.sh" --config "${CONFIG_FILE}" "$@"
		;;
	archive-completed)
		exec "${TMUX_DIR}/archive-completed.sh" --config "${CONFIG_FILE}" "$@"
		;;
	task)
		exec "${TMUX_DIR}/new-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	start-task)
		exec "${TMUX_DIR}/start-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	task-from-spec)
		exec "${TMUX_DIR}/start-task-from-spec.sh" --config "${CONFIG_FILE}" "$@"
		;;
	dispatch)
		exec "${TMUX_DIR}/dispatch.sh" --config "${CONFIG_FILE}" "$@"
		;;
	review)
		exec "${TMUX_DIR}/review-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	start-review)
		exec "${TMUX_DIR}/start-review.sh" --config "${CONFIG_FILE}" "$@"
		;;
	handoff)
		exec "${TMUX_DIR}/handoff.sh" --config "${CONFIG_FILE}" "$@"
		;;
	cleanup)
		exec "${TMUX_DIR}/cleanup-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	*)
		echo "error: unknown command '${COMMAND}'" >&2
		echo >&2
		usage >&2
		exit 1
		;;
esac
