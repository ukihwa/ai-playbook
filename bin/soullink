#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SOURCE_PATH}" ]]; do
	SOURCE_DIR="$(cd -P "$(dirname "${SOURCE_PATH}")" && pwd)"
	SOURCE_PATH="$(readlink "${SOURCE_PATH}")"
	[[ "${SOURCE_PATH}" != /* ]] && SOURCE_PATH="${SOURCE_DIR}/${SOURCE_PATH}"
done
ROOT_DIR="$(cd -P "$(dirname "${SOURCE_PATH}")/.." && pwd)"
CONFIG_FILE="${ROOT_DIR}/config/soullink.env"
TMUX_DIR="${ROOT_DIR}/scripts/tmux"

usage() {
	cat <<'EOF'
Usage: soullink <command> [args]

Commands:
  up                     Create the base soullink tmux session
  up-bootstrap           Create the base session and bootstrap default Claude panes
  dev                    Create the base session and start FE/BE runtimes
  all                    Create the base session, bootstrap defaults, and start FE/BE runtimes
  run <fe|be|app>        Start a configured runtime window
  stop-run <fe|be|app>   Stop a configured runtime window
  status                 Show tmux and worktree status
  task <target> <slug>   Create a worker window and worktree
  start-task <target> <slug> [flags...]
                         Create a worker, generate handoff, and send it
  task-from-spec <target> <slug> <file> [flags...]
                         Start a task from a spec or issue markdown file
  review <target> <slug> [flags...]
                         Create a review window
  start-review <target> <slug> [flags...]
                         Create a review window, generate artifact, and send it
  handoff <window> <file> [flags...]
                         Send an existing handoff file into a pane
  cleanup <target> <slug> [--delete-worktree]
                         Remove task/review windows and optionally the worktree
  help                   Show this help
EOF
}

need_script() {
	local path="$1"
	[[ -x "${path}" ]] || {
		echo "error: missing executable: ${path}" >&2
		exit 1
	}
}

for script in \
	"${TMUX_DIR}/init-product.sh" \
	"${TMUX_DIR}/start-runtime.sh" \
	"${TMUX_DIR}/stop-runtime.sh" \
	"${TMUX_DIR}/status.sh" \
	"${TMUX_DIR}/new-task.sh" \
	"${TMUX_DIR}/start-task.sh" \
	"${TMUX_DIR}/start-task-from-spec.sh" \
	"${TMUX_DIR}/review-task.sh" \
	"${TMUX_DIR}/start-review.sh" \
	"${TMUX_DIR}/handoff.sh" \
	"${TMUX_DIR}/cleanup-task.sh"
do
	need_script "${script}"
done

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
	shift
fi

case "${COMMAND}" in
	up)
		exec "${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" "$@"
		;;
	up-bootstrap)
		exec "${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" --bootstrap-defaults "$@"
		;;
	dev)
		"${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" "$@"
		"${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait be
		exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait fe
		;;
	all)
		"${TMUX_DIR}/init-product.sh" --config "${CONFIG_FILE}" --bootstrap-defaults "$@"
		"${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait be
		exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" --wait fe
		;;
	run)
		exec "${TMUX_DIR}/start-runtime.sh" --config "${CONFIG_FILE}" "$@"
		;;
	stop-run)
		exec "${TMUX_DIR}/stop-runtime.sh" --config "${CONFIG_FILE}" "$@"
		;;
	status)
		exec "${TMUX_DIR}/status.sh" --config "${CONFIG_FILE}" "$@"
		;;
	task)
		exec "${TMUX_DIR}/new-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	start-task)
		exec "${TMUX_DIR}/start-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	task-from-spec)
		exec "${TMUX_DIR}/start-task-from-spec.sh" --config "${CONFIG_FILE}" "$@"
		;;
	review)
		exec "${TMUX_DIR}/review-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	start-review)
		exec "${TMUX_DIR}/start-review.sh" --config "${CONFIG_FILE}" "$@"
		;;
	handoff)
		exec "${TMUX_DIR}/handoff.sh" --config "${CONFIG_FILE}" "$@"
		;;
	cleanup)
		exec "${TMUX_DIR}/cleanup-task.sh" --config "${CONFIG_FILE}" "$@"
		;;
	help|-h|--help)
		usage
		;;
	*)
		echo "error: unknown command '${COMMAND}'" >&2
		echo >&2
		usage >&2
		exit 1
		;;
esac
