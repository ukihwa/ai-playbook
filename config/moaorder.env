PRODUCT_NAME=moaorder
TMUX_SESSION=moaorder
DEFAULT_BRANCH=main

WORK_ROOT=/Users/ukihwa/dev/studio
WORKTREE_ROOT=/Users/ukihwa/dev/studio/worktrees/moaorder
TRIAGE_DIR=/Users/ukihwa/dev/studio/moaorder
DISPATCH_TICKET_ROOT=/Users/ukihwa/dev/studio/moaorder/.dispatch-tickets
DISPATCH_INBOX_ROOT=/Users/ukihwa/dev/studio/moaorder/docs/tasks/dispatch-inbox
INTAKE_AUDIT_ROOT=/Users/ukihwa/dev/studio/moaorder/.intake-audit
DISPATCH_AUTO_APPLY=true
DISPATCH_AUTO_APPLY_MIN_CONFIDENCE=0.75
DISPATCH_AUTO_APPLY_ALLOWED_TARGETS=frontend,app
DISPATCH_AUTO_APPLY_BLOCK_REVIEW_ONLY=true
DISPATCH_AUTO_APPLY_BLOCK_CROSS_VERIFY=true

AGENT_CLAUDE_CMD=/Users/ukihwa/.local/bin/claude
AGENT_CODEX_CMD=/Applications/Codex.app/Contents/Resources/codex
AGENT_GEMINI_CMD=/Users/ukihwa/.local/bin/gemini

TARGET_FRONTEND=/Users/ukihwa/dev/studio/moaorder/frontend
TARGET_AI_SERVICE=/Users/ukihwa/dev/studio/moaorder/ai-service
TARGET_PRO_WEB=/Users/ukihwa/dev/studio/moaorder/frontend
TARGET_BACKEND=/Users/ukihwa/dev/studio/moaorder/frontend
TARGET_APP=/Users/ukihwa/dev/studio/moaorder/frontend

DISPATCH_DEFAULT_TARGET=frontend
DISPATCH_WEB_TARGET=frontend
DISPATCH_BACKEND_TARGET=frontend
DISPATCH_APP_TARGET=frontend
DISPATCH_AI_TARGET=ai-service
DISPATCH_DOC_UPDATE_FRONTEND=/Users/ukihwa/dev/studio/moaorder/docs/roles-and-routes.md
DISPATCH_DOC_UPDATE_BACKEND=/Users/ukihwa/dev/studio/moaorder/docs/auth-flow.md
DISPATCH_DOC_UPDATE_AI_SERVICE=/Users/ukihwa/dev/studio/moaorder/ai-service/README.md

RUN_FE_DIR=/Users/ukihwa/dev/studio/moaorder/frontend
RUN_BE_DIR=/Users/ukihwa/dev/studio/moaorder/ai-service
RUN_BE_PRE_CMD="PATH=\"/opt/homebrew/bin:/usr/local/bin:\$PATH\"; docker info >/dev/null 2>&1 || docker desktop start --detach; until docker info >/dev/null 2>&1; do sleep 1; done; docker compose -f ../docker-compose.yml up -d postgres redis"
RUN_BE_PRE_WAIT_PORTS=5432,6379
RUN_FE_CMD="corepack pnpm dev"
RUN_BE_CMD="uv run uvicorn app.main:app --reload --port 8000"
RUN_FE_WAIT_PORTS=5173
RUN_BE_WAIT_PORTS=8000

CLAUDE_FE_DIR=/Users/ukihwa/dev/studio/moaorder/frontend
CLAUDE_BE_DIR=/Users/ukihwa/dev/studio/moaorder/ai-service
