PRODUCT_NAME=example-product
TMUX_SESSION=example-product
DEFAULT_BRANCH=main

WORK_ROOT=/absolute/path/to/work
WORKTREE_ROOT=/absolute/path/to/worktrees/example-product
TRIAGE_DIR=/absolute/path/to/work
DISPATCH_TICKET_ROOT=/absolute/path/to/work/.dispatch-tickets

AGENT_CLAUDE_CMD=claude
AGENT_CODEX_CMD=codex
AGENT_GEMINI_CMD=gemini

TARGET_FE=/absolute/path/to/work/example-frontend
TARGET_BE=/absolute/path/to/work/example-backend
TARGET_APP=/absolute/path/to/work/example-app

RUN_FE_DIR=/absolute/path/to/work/example-frontend
RUN_BE_DIR=/absolute/path/to/work/example-backend
RUN_APP_DIR=/absolute/path/to/work/example-app
RUN_BE_PRE_CMD="PATH=\"/opt/homebrew/bin:/usr/local/bin:\$PATH\"; docker info >/dev/null 2>&1 || docker desktop start --detach; until docker info >/dev/null 2>&1; do sleep 1; done; docker compose -f docker-compose.local.yml up -d db redis"
RUN_BE_PRE_WAIT_PORTS=5432,6379
RUN_FE_CMD="pnpm dev"
RUN_BE_CMD="uv run uvicorn app.main:app --reload"
RUN_APP_CMD="flutter run"
RUN_FE_WAIT_PORTS=3000
RUN_BE_WAIT_PORTS=8000
RUN_APP_WAIT_PORTS=

CLAUDE_FE_DIR=/absolute/path/to/work/example-frontend
CLAUDE_BE_DIR=/absolute/path/to/work/example-backend
CLAUDE_APP_DIR=/absolute/path/to/work/example-app
