PRODUCT_NAME=soullink
TMUX_SESSION=soullink
DEFAULT_BRANCH=main

WORK_ROOT=/Users/ukihwa/dev/work
WORKTREE_ROOT=/Users/ukihwa/dev/worktrees/soullink
TRIAGE_DIR=/Users/ukihwa/dev/work/soullink-kiosk-pro-web
DISPATCH_TICKET_ROOT=/Users/ukihwa/dev/work/soullink-kiosk-pro-web/.dispatch-tickets
DISPATCH_INBOX_ROOT=/Users/ukihwa/dev/work/soullink-kiosk-pro-web/docs/tasks/dispatch-inbox

AGENT_CLAUDE_CMD=/Users/ukihwa/.local/bin/claude
AGENT_CODEX_CMD=/Applications/Codex.app/Contents/Resources/codex
AGENT_GEMINI_CMD=/Users/ukihwa/.local/bin/gemini

TARGET_PRO_WEB=/Users/ukihwa/dev/work/soullink-kiosk-pro-web
TARGET_BACKEND=/Users/ukihwa/dev/work/soullink-kiosk-backend
TARGET_APP=/Users/ukihwa/dev/work/soullink_kiosk_app

RUN_FE_DIR=/Users/ukihwa/dev/work/soullink-kiosk-pro-web
RUN_BE_DIR=/Users/ukihwa/dev/work/soullink-kiosk-backend
RUN_APP_DIR=/Users/ukihwa/dev/work/soullink_kiosk_app
RUN_BE_PRE_CMD="PATH=\"/opt/homebrew/bin:/usr/local/bin:\$PATH\"; docker info >/dev/null 2>&1 || docker desktop start --detach; until docker info >/dev/null 2>&1; do sleep 1; done; docker compose -f docker-compose.local.yml up -d db redis"
RUN_BE_PRE_WAIT_PORTS=5432,6379
RUN_FE_CMD="corepack pnpm dev"
RUN_BE_CMD="uv run uvicorn app.main:app --reload --port 8000"
RUN_APP_CMD="flutter run"
RUN_FE_WAIT_PORTS=3000
RUN_BE_WAIT_PORTS=8000
RUN_APP_WAIT_PORTS=

CLAUDE_FE_DIR=/Users/ukihwa/dev/work/soullink-kiosk-pro-web
CLAUDE_BE_DIR=/Users/ukihwa/dev/work/soullink-kiosk-backend
CLAUDE_APP_DIR=/Users/ukihwa/dev/work/soullink_kiosk_app
